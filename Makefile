# ==============================================================================
# НАСТРОЙКИ КОМПИЛЯТОРА И СБОРКИ ЭМУЛЯТОРА PDP-11
# ==============================================================================

# Имя компилятора
CC = gcc

# Флаги компиляции (CFLAGS):
# -Wall -Wextra : включаем максимальное число предупреждений компилятора
# -Werror       : трактуем предупреждения как ошибки (заставляет писать чистый код)
# -Isrc         : указываем компилятору искать заголовочные файлы (.h) в папке src
# -g            : добавляем отладочную информацию (нужно для работы санитайзеров)
# -O0           : отключаем оптимизацию кода для точной и удобной отладки в IDE
CFLAGS = -Wall -Wextra -Werror -Isrc -g -O0

# Подключаемые библиотеки и встроенная защита (LIBS):
# -lm                  : подключаем стандартную математическую библиотеку C
# -fsanitize=address   : включаем защиту ASan (мгновенно роняет программу при выходе за границы памяти)
# -fsanitize=undefined : включаем защиту UBSan (отслеживает неопределенное поведение, например сдвиг битов)
LIBS = -lm -fsanitize=address -fsanitize=undefined

# Список всех исходных файлов, которые нужно скомпилировать
SOURCES = src/pdp11.c src/memory.c src/logger.c src/cpu.c src/tests.c

# Имя финального исполняемого файла (собирается в изолированную папку build)
TARGET = build/pdp11

# ==============================================================================
# ПРАВИЛА СБОРКИ
# ==============================================================================

# Правило по умолчанию (вызывается в терминале простой командой "make")
all: $(TARGET)

# Главное правило сборки исполняемого файла
$(TARGET): $(SOURCES)
	mkdir -p build
	$(CC) $(CFLAGS) $(SOURCES) -o $(TARGET) $(LIBS)

# Режим Релиза (вызывается командой "make release")
# Отключает тяжелые санитайзеры и включает максимальную оптимизацию скорости (-O3)
release: CFLAGS = -Wall -Wextra -Werror -Isrc -O3
release: LIBS = -lm
release: clean $(TARGET)

# Очистка проекта (вызывается командой "make clean")
# Полностью и безопасно удаляет папку build со всем содержимым
clean:
	rm -rf build

# Указываем, что эти правила являются командами, а не именами реальных файлов
.PHONY: all clean release
